PORT=5000
MONGO_URI=mongodb://localhost:27017/chronicle
JWT_SECRET=change_this_to_a_secure_random_string
NODE_ENV=development

# Cloudinary — get these from cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
